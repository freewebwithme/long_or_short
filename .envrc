# direnv config — auto-loads dev secrets when entering this directory.
#
# Setup (one-time):
#   1. Install direnv:           sudo pacman -S direnv
#   2. Hook into zsh:            echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc
#   3. Allow this directory:     direnv allow .
#
# After that, every shell that cd's into this project gets the secrets
# from envs/.dev.env exported automatically. `cd ..` unloads them.
#
# Both this file and envs/ are project-scoped — no global pollution of ~/.zshrc.

dotenv envs/.dev.env
