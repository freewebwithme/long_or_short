# Long or Short -- environment variables example.
# Copy this file to envs/.env (git-ignored) and fill in real values.
# `config/runtime.exs` reads these via Dotenvy at boot.

# ---------------------------------------------------------------
# AI provider selection (LON-104)
# ---------------------------------------------------------------
# Which provider serves all LLM calls.
#   "claude" -- Anthropic Claude (default)
#   "qwen"   -- Alibaba Qwen via DashScope (cost alternative)
AI_PROVIDER=claude

# ---------------------------------------------------------------
# Anthropic (used when AI_PROVIDER=claude)
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------
# Qwen / Alibaba DashScope (LON-104, used when AI_PROVIDER=qwen)
# ---------------------------------------------------------------
# Region of the DashScope endpoint to hit.
#   "singapore" -- free tier (1M in + 1M out per model, 90 days);
#                  dev / test / MVP
#   "us"        -- pay-as-you-go (US Virginia); production-quality
#                  latency, no free quota
#
# API keys are NOT interchangeable across regions. Set the key
# issued from the matching region's console.
QWEN_REGION=singapore
QWEN_API_KEY=

# ---------------------------------------------------------------
# Finnhub (price + news feed)
# ---------------------------------------------------------------
FINNHUB_API_KEY=

# ---------------------------------------------------------------
# SEC EDGAR (filings feeder + body fetcher)
# ---------------------------------------------------------------
# SEC requires a real contact User-Agent on every request.
# Format: "Your Name your@email.example"
SEC_USER_AGENT=
