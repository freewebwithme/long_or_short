# ── Phoenix ──────────────────────────────────────────────────────────
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=your_secret_key_base_here
TOKEN_SIGNING_SECRET=your_token_signing_secret_here

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=ecto://USER:PASS@HOST/DATABASE

# ── News Sources ─────────────────────────────────────────────────────
# Finnhub free tier: https://finnhub.io (sign up to get a key)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpaca News API (LON-128) — free with a paper-trading account.
# 1. Sign up:    https://app.alpaca.markets/signup
# 2. Switch to Paper mode (account-number toggle, upper-left of dashboard)
# 3. Generate keys from the Home section
# Secret key is shown ONLY ONCE at creation — save it immediately.
# Paper account keys work against `data.alpaca.markets` (news API).
ALPACA_API_KEY_ID=your_alpaca_paper_key_id_here
ALPACA_API_SECRET_KEY=your_alpaca_paper_secret_key_here

# ── AI Analysis ──────────────────────────────────────────────────────
# Anthropic API: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# ── Optional ─────────────────────────────────────────────────────────
# PHX_HOST=example.com
# PHX_SERVER=true
# PORT=4000
# ECTO_IPV6=false
# DNS_CLUSTER_QUERY=your_dns_query

# Required for SEC EDGAR API. Format: "AppName contact@email.com"
SEC_USER_AGENT=
